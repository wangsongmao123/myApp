/* pages/address/address.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 地址列表 */
.address-list {
  padding: 20rpx;
}

.address-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.address-card.default {
  border: 2rpx solid #ff6b35;
}

.addr-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.addr-user-info {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.addr-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.addr-phone {
  font-size: 26rpx;
  color: #999;
}

.addr-actions {
  display: flex;
  gap: 20rpx;
}

.edit-btn {
  font-size: 24rpx;
  color: #ff6b35;
}

.addr-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.addr-bottom {
  margin-top: 12rpx;
}

.default-tag {
  font-size: 20rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 空状态 */
.empty-state {
  padding: 160rpx 0;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
  display: block;
}

/* 新增按钮 */
.add-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b35, #f7931e);
  color: #fff;
  padding: 24rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  gap: 10rpx;
}

.add-icon {
  font-size: 36rpx;
  line-height: 1;
}

/* 弹窗 */
.popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  visibility: hidden;
}

.popup.show {
  visibility: visible;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s;
}

.popup.show .popup-mask {
  opacity: 1;
}

.popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.popup.show .popup-content {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
}

.popup-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  width: 140rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.popup-footer {
  padding-top: 30rpx;
}

.save-btn {
  background: linear-gradient(135deg, #ff6b35, #f7931e);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.save-btn:active {
  opacity: 0.8;
}
