/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 顶部定位栏 */
.header {
  background: linear-gradient(135deg, #ff6b35, #f7931e);
  padding: 20rpx 30rpx 30rpx;
  display: flex;
  align-items: center;
}

.location {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  white-space: nowrap;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 6rpx;
}

.location-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow-icon {
  width: 20rpx;
  height: 20rpx;
  margin-left: 4rpx;
}

.search-box {
  flex: 1;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
  opacity: 0.7;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
}

/* 分类入口 */
.categories {
  background: #fff;
  display: flex;
  justify-content: space-around;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
}

.cate-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cate-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 8rpx;
  background: #fff5f0;
  border-radius: 16rpx;
  padding: 12rpx;
}

.cate-name {
  font-size: 22rpx;
  color: #666;
}

/* 横幅 */
.banner {
  margin: 0 20rpx 20rpx;
  height: 240rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

/* 商家列表 */
.shop-section {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-bar {
  display: flex;
  gap: 20rpx;
}

.filter-item {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.filter-item.active {
  color: #ff6b35;
  background: #fff5f0;
  font-weight: bold;
}

/* 商家卡片 */
.shop-list {
  display: flex;
  flex-direction: column;
}

.shop-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.shop-card:last-child {
  border-bottom: none;
}

.shop-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.shop-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.shop-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.shop-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-tag {
  font-size: 18rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  border: 1rpx solid #ffe0d0;
}

.shop-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.star {
  font-size: 22rpx;
}

.rating {
  color: #ff6b35;
  font-weight: bold;
}

.sales {
  margin-left: 10rpx;
}

.meta-right {
  display: flex;
  gap: 16rpx;
}

.shop-bottom {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #999;
}

.shop-notice {
  background: #fff9f5;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #ff9966;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #ccc;
}
