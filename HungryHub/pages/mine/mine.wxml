<!--pages/mine/mine.wxml-->
<view class="container">
  <!-- 用户头部 -->
  <view class="user-header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="nickname">{{userInfo.nickName || '点击登录'}}</text>
        <text class="user-phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
      </view>
    </view>
    <view class="header-right" wx:if="{{!userInfo.nickName}}" bindtap="getUserProfile">
      <text class="login-btn">登录</text>
    </view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="all-orders" bindtap="goOrders" data-tab="all">
        <text>全部订单</text>
        <image class="arrow-icon" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
    </view>
    <view class="order-entries">
      <view class="order-entry" bindtap="goOrders" data-tab="pending">
        <image class="entry-icon" src="/images/order-pending.png" mode="aspectFit"></image>
        <text class="entry-text">待支付</text>
        <view class="entry-badge" wx:if="{{pendingCount > 0}}">{{pendingCount}}</view>
      </view>
      <view class="order-entry" bindtap="goOrders" data-tab="delivering">
        <image class="entry-icon" src="/images/order-delivering.png" mode="aspectFit"></image>
        <text class="entry-text">配送中</text>
        <view class="entry-badge" wx:if="{{deliveringCount > 0}}">{{deliveringCount}}</view>
      </view>
      <view class="order-entry" bindtap="goOrders" data-tab="completed">
        <image class="entry-icon" src="/images/order-completed.png" mode="aspectFit"></image>
        <text class="entry-text">已完成</text>
      </view>
      <view class="order-entry">
        <image class="entry-icon" src="/images/order-service.png" mode="aspectFit"></image>
        <text class="entry-text">售后</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goAddress">
      <image class="menu-icon" src="/images/menu-address.png" mode="aspectFit"></image>
      <text class="menu-text">收货地址</text>
      <image class="arrow-icon" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
    <view class="menu-item">
      <image class="menu-icon" src="/images/menu-coupon.png" mode="aspectFit"></image>
      <text class="menu-text">优惠券</text>
      <text class="menu-value">2张可用</text>
      <image class="arrow-icon" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
    <view class="menu-item">
      <image class="menu-icon" src="/images/menu-fav.png" mode="aspectFit"></image>
      <text class="menu-text">我的收藏</text>
      <image class="arrow-icon" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item">
      <image class="menu-icon" src="/images/menu-service.png" mode="aspectFit"></image>
      <text class="menu-text">客服中心</text>
      <image class="arrow-icon" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
    <view class="menu-item">
      <image class="menu-icon" src="/images/menu-about.png" mode="aspectFit"></image>
      <text class="menu-text">关于我们</text>
      <text class="menu-value">v1.0.0</text>
      <image class="arrow-icon" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
    <view class="menu-item">
      <image class="menu-icon" src="/images/menu-setting.png" mode="aspectFit"></image>
      <text class="menu-text">设置</text>
      <image class="arrow-icon" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" wx:if="{{userInfo.nickName}}" bindtap="logout">
    <text>退出登录</text>
  </view>
</view>
