/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索框 */
.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  gap: 16rpx;
}

.search-input-box {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 100%;
}

.clear-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

.cancel-btn {
  color: #ff6b35;
  font-size: 28rpx;
  white-space: nowrap;
}

/* 搜索历史 */
.search-history,
.hot-search {
  background: #fff;
  margin-top: 20rpx;
  padding: 24rpx;
}

.history-header,
.hot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title,
.hot-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.clear-history {
  font-size: 24rpx;
  color: #999;
}

.history-tags,
.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag,
.hot-tag {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.hot-tag {
  color: #ff6b35;
  background: #fff5f0;
}

/* 搜索结果 */
.search-results {
  margin-top: 20rpx;
}

.result-header {
  padding: 16rpx 24rpx;
}

.result-count {
  font-size: 24rpx;
  color: #999;
}

.shop-list {
  background: #fff;
}

.shop-card {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  align-items: center;
}

.shop-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.shop-info {
  flex: 1;
}

.shop-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.shop-meta {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.star {
  color: #ff6b35;
}

.sales {
  margin-left: 16rpx;
}

.shop-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

/* 空结果 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}
