<!--pages/shop/shop.wxml-->
<view class="container">
  <!-- 商家头部 -->
  <view class="shop-header">
    <image class="shop-bg" src="{{shop.logo}}" mode="aspectFill"></image>
    <view class="shop-header-info">
      <image class="shop-avatar" src="{{shop.logo}}" mode="aspectFill"></image>
      <view class="shop-header-text">
        <text class="shop-title">{{shop.name}}</text>
        <view class="shop-header-meta">
          <text class="star">⭐ {{shop.rating}}</text>
          <text class="sales">月售{{shop.monthlySales}}</text>
          <text class="time">{{shop.deliveryTime}}</text>
        </view>
        <view class="shop-header-bottom">
          <text>¥{{shop.minPrice}}起送</text>
          <text>|</text>
          <text>配送费¥{{shop.deliveryFee}}</text>
          <text>|</text>
          <text>{{shop.distance}}</text>
        </view>
      </view>
    </view>
    <view class="shop-notice">
      <text class="notice-label">公告：</text>
      <text class="notice-content">{{shop.notice}}</text>
    </view>
  </view>

  <!-- 分类导航 -->
  <scroll-view class="cate-nav" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="cate-nav-item {{activeCate===index?'active':''}}" 
          wx:for="{{shop.categories}}" wx:key="*this" 
          bindtap="switchCate" data-index="{{index}}">
      {{item}}
    </view>
  </scroll-view>

  <!-- 菜品列表 -->
  <scroll-view class="food-list" scroll-y enhanced scroll-into-view="{{'cate-'+activeCate}}" scroll-with-animation>
    <view class="cate-section" wx:for="{{shop.categories}}" wx:key="*this" wx:for-index="cateIdx" id="cate-{{cateIdx}}">
      <view class="cate-title">{{item}}</view>
      <view class="food-item" wx:for="{{shop.foods}}" wx:for-item="food" wx:key="id" wx:if="{{food.cate===item}}">
        <image class="food-img" src="{{food.img}}" mode="aspectFill"></image>
        <view class="food-info">
          <text class="food-name">{{food.name}}</text>
          <text class="food-desc">{{food.desc}}</text>
          <text class="food-sales">月售{{food.sales}}</text>
          <view class="food-bottom">
            <text class="food-price">¥{{food.price}}</text>
            <view class="food-actions">
              <view class="action-btn reduce" bindtap="reduceFood" data-food="{{food}}" wx:if="{{cartItems[food.id+food.spec]}}">
                <text class="action-text">-</text>
              </view>
              <text class="food-count" wx:if="{{cartItems[food.id+food.spec]}}">{{cartItems[food.id+food.spec].count}}</text>
              <view class="action-btn add" bindtap="addFood" data-food="{{food}}">
                <text class="action-text">+</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <!-- 底部占位，给购物车留空间 -->
    <view style="height: 140rpx;"></view>
  </scroll-view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar" wx:if="{{cartTotalCount > 0}}">
    <view class="cart-icon-wrap" bindtap="toggleCart">
      <image class="cart-icon" src="/images/cart.png" mode="aspectFit"></image>
      <view class="cart-badge" wx:if="{{cartTotalCount > 0}}">{{cartTotalCount}}</view>
    </view>
    <view class="cart-info">
      <text class="cart-price">¥{{cartTotalPrice}}</text>
      <text class="cart-tip" wx:if="{{cartTotalPrice < shop.minPrice}}">还差¥{{priceDiff}}起送</text>
      <text class="cart-tip" wx:else>另需配送费¥{{shop.deliveryFee}}</text>
    </view>
    <view class="cart-btn {{cartTotalPrice >= shop.minPrice ? 'can-order' : ''}}" bindtap="goPayment">
      {{cartTotalPrice >= shop.minPrice ? '去结算' : '¥'+shop.minPrice+'起送'}}
    </view>
  </view>

  <!-- 购物车弹层 -->
  <view class="cart-popup {{showCart?'show':''}}">
    <view class="cart-mask" bindtap="hideCart"></view>
    <view class="cart-content">
      <view class="cart-popup-header">
        <text class="cart-popup-title">购物车</text>
        <text class="cart-clear" bindtap="clearCart">清空</text>
      </view>
      <scroll-view class="cart-list" scroll-y>
        <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
          <text class="cart-item-name">{{item.name}}</text>
          <view class="cart-item-right">
            <text class="cart-item-price">¥{{item.subtotal}}</text>
            <view class="food-actions small">
              <view class="action-btn reduce" bindtap="reduceFood" data-food="{{item}}">
                <text class="action-text">-</text>
              </view>
              <text class="food-count">{{item.count}}</text>
              <view class="action-btn add" bindtap="addFood" data-food="{{item}}">
                <text class="action-text">+</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
