/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
  color: #333;
}

.container {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #ff6b35, #f7931e);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 价格样式 */
.price {
  color: #ff6b35;
  font-weight: bold;
}

.price::before {
  content: '¥';
  font-size: 0.7em;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-state text {
  font-size: 28rpx;
}
